# =============================================================================
# FRONTEND (.env) – only VITE_-prefixed vars are exposed to the browser
# =============================================================================

# Supabase URL (local, self-hosted or cloud)
VITE_SUPABASE_URL=http://localhost:8000
# The 'anon' / 'public' key from Supabase Studio (Settings -> API)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR...

# Feature flag: set to 'false' to use the real Supabase backend instead of
# mock data. Defaults to mock when unset or when Supabase is not configured.
VITE_USE_MOCK_DATA=true

# Backend AI proxy endpoint (services/aiService.ts). Defaults to localhost:3000.
VITE_BACKEND_URL=http://localhost:3000/api/generate

# OPTIONAL: explicit client key ONLY for the realtime voice (Live) API in
# CallAgent, which cannot use the server proxy. Leave empty to disable voice.
# WARNING: this key IS shipped to the browser – use a restricted key.
VITE_GEMINI_LIVE_KEY=

# =============================================================================
# BACKEND (backend/.env) – never exposed to the browser
# =============================================================================
# GOOGLE_API_KEY=your-server-side-gemini-key
# FRONTEND_URL=http://localhost:5173

# Backend origin (no path) for drive integrations. If unset, derived from
# VITE_BACKEND_URL by stripping /api/generate.
VITE_API_BASE_URL=http://localhost:3000
