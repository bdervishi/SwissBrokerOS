# Backend (never exposed to the browser)
PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:3000

# AI proxy
GOOGLE_API_KEY=your-server-side-gemini-key

# Supabase (service role – server-side only!) for storing tenant integration tokens
SUPABASE_URL=https://your-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OAuth apps (see docs/INTEGRATIONS.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# Deadline automation: shared secret for the manual trigger
# (POST /api/automation/run, header x-automation-key). The daily 06:00 cron runs automatically.
AUTOMATION_SECRET=

# Hardening: 32-byte key (hex/base64/raw) to encrypt integration tokens at rest
ENCRYPTION_KEY=
# HMAC secret for signed OAuth state (defaults to ENCRYPTION_KEY if unset)
STATE_SECRET=
